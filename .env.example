# required
ANTHROPIC_API_KEY=sk-ant-...

# optional: enables OpenAI models in the benchmark + as fallback targets
OPENAI_API_KEY=sk-proj-...

# infra (defaults match docker-compose)
DATABASE_URL=postgres://glacis:glacis@localhost:5432/glacis
REDIS_URL=redis://localhost:6379

# service
PORT=3000
PRIMARY_MODEL=claude-haiku-4-5-20251001
FALLBACK_MODEL=claude-sonnet-4-6
MAX_ATTEMPTS=3
WORKER_CONCURRENCY=8
REVIEW_CONFIDENCE=0.7
